---
interface Props {
  number?: number | string;
}
const { number } = Astro.props;
---

<aside class="my-8 not-prose">
  <details class="group rounded-lg border border-cyan/20 bg-cyan/[0.03] hover:bg-cyan/[0.05] transition-colors">
    <summary class="cursor-pointer px-5 py-4 flex items-start gap-3 list-none [&::-webkit-details-marker]:hidden">
      <div class="flex-shrink-0 mt-0.5">
        <div class="w-6 h-6 rounded-full bg-cyan/15 border border-cyan/30 flex items-center justify-center text-[11px] font-bold text-cyan">
          {number ?? "?"}
        </div>
      </div>
      <div class="flex-1">
        <div class="text-[10px] uppercase tracking-[0.12em] text-cyan font-bold mb-1">Active Recall</div>
        <div class="text-[15px] text-text font-medium leading-snug">
          <slot name="question" />
        </div>
      </div>
      <svg class="flex-shrink-0 mt-1 text-text-muted transition-transform group-open:rotate-180" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </summary>
    <div class="px-5 pb-5 pl-14 -mt-1 text-[14.5px] text-text-dim leading-relaxed border-t border-cyan/10 pt-4">
      <slot />
    </div>
  </details>
</aside>
