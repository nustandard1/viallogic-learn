---
const pathname = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Course" },
  { href: "/about", label: "About" },
];
---

<header class="sticky top-0 z-50 border-b border-border/50 bg-bg/80 backdrop-blur-xl">
  <div class="max-w-[var(--container-wide)] mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-[15px] font-semibold tracking-tight">
        Vial<span class="text-cyan">Logic</span>
        <span class="text-text-muted font-normal ml-1">Learn</span>
      </span>
    </a>

    <nav class="flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-3 py-1.5 text-[13px] font-medium rounded-md transition-colors",
            pathname === item.href
              ? "text-text bg-elevated"
              : "text-text-muted hover:text-text hover:bg-elevated/50"
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://www.viallogic.com"
        class="ml-3 px-3 py-1.5 text-[13px] font-medium text-cyan border border-cyan/20 rounded-md hover:bg-cyan/5 transition-colors flex items-center gap-1.5"
      >
        Calculator
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>
    </nav>
  </div>
</header>
