---
interface Step { label: string; sub?: string; }
interface Props {
  title: string;
  trigger: string;
  steps: Step[];
  outcome: string;
  color?: "cyan" | "purple" | "emerald";
  caption?: string;
}
const { title, trigger, steps, outcome, color = "cyan", caption } = Astro.props;

const palette = {
  cyan: { dot: "#00d4ff", line: "rgba(0,212,255,0.4)", glow: "rgba(0,212,255,0.08)" },
  purple: { dot: "#a855f7", line: "rgba(168,85,247,0.4)", glow: "rgba(168,85,247,0.08)" },
  emerald: { dot: "#10b981", line: "rgba(16,185,129,0.4)", glow: "rgba(16,185,129,0.08)" },
};
const c = palette[color];
---

<figure class="not-prose my-10 rounded-xl border border-border bg-card overflow-hidden">
  <header class="px-6 py-4 border-b border-border bg-elevated/40 flex items-center justify-between">
    <div>
      <div class="text-[10px] uppercase tracking-[0.14em] font-bold" style={`color:${c.dot}`}>Signaling Cascade</div>
      <div class="text-[15px] font-semibold text-text mt-0.5">{title}</div>
    </div>
    <div class="text-[11px] font-mono text-text-muted hidden sm:block">{trigger}</div>
  </header>

  <div class="px-6 py-8">
    <ol class="relative space-y-3">
      <li class="relative flex items-start gap-4 pl-2">
        <span class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-[11px] font-bold mt-0.5" style={`background:${c.glow};color:${c.dot};border:1px solid ${c.line}`}>1</span>
        <div class="flex-1 pt-1">
          <div class="text-[14px] font-semibold text-text">{trigger}</div>
          <div class="text-[12.5px] text-text-muted mt-0.5">Ligand binds receptor — the trigger event.</div>
        </div>
      </li>
      {steps.map((s, i) => (
        <>
          <li class="relative flex items-center pl-6">
            <svg width="14" height="20" viewBox="0 0 14 20" fill="none"><line x1="7" y1="0" x2="7" y2="14" stroke={c.line} stroke-width="2" /><polygon points="7,20 3,12 11,12" fill={c.line.replace(/0\.4/, "0.7")} /></svg>
          </li>
          <li class="relative flex items-start gap-4 pl-2">
            <span class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-[11px] font-bold mt-0.5" style={`background:${c.glow};color:${c.dot};border:1px solid ${c.line}`}>{i + 2}</span>
            <div class="flex-1 pt-1">
              <div class="text-[14px] font-semibold text-text">{s.label}</div>
              {s.sub && <div class="text-[12.5px] text-text-muted mt-0.5">{s.sub}</div>}
            </div>
          </li>
        </>
      ))}
      <li class="relative flex items-center pl-6">
        <svg width="14" height="20" viewBox="0 0 14 20" fill="none"><line x1="7" y1="0" x2="7" y2="14" stroke={c.line} stroke-width="2" /><polygon points="7,20 3,12 11,12" fill={c.line.replace(/0\.4/, "0.7")} /></svg>
      </li>
      <li class="relative flex items-start gap-4 pl-2">
        <span class="flex-shrink-0 w-8 h-8 rounded-md flex items-center justify-center mt-0.5" style={`background:${c.dot};color:#0a0a0a`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <div class="flex-1 pt-1">
          <div class="text-[10px] uppercase tracking-[0.14em] font-bold" style={`color:${c.dot}`}>Outcome</div>
          <div class="text-[14.5px] font-medium text-text mt-0.5">{outcome}</div>
        </div>
      </li>
    </ol>
  </div>

  {caption && <figcaption class="px-6 py-3 border-t border-border text-[12px] text-text-muted">{caption}</figcaption>}
</figure>
