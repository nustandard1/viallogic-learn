---
interface Compound {
  name: string;
  halfLife: string;
  halfLifeMin: number; // numeric, in minutes (for sorting/visual)
  color?: string;
}
interface Props {
  compounds: Compound[];
  caption?: string;
}
const { compounds, caption } = Astro.props;

// Build SVG curve points for each compound
const w = 720, h = 260, pad = { l: 60, r: 30, t: 20, b: 50 };
const innerW = w - pad.l - pad.r, innerH = h - pad.t - pad.b;
const maxX = Math.max(...compounds.map(c => c.halfLifeMin * 5)); // show out to 5 half-lives
const buildPath = (hlMin: number) => {
  const pts: string[] = [];
  const N = 120;
  for (let i = 0; i <= N; i++) {
    const t = (i / N) * maxX;
    const y = Math.pow(0.5, t / hlMin); // fraction remaining
    const px = pad.l + (t / maxX) * innerW;
    const py = pad.t + (1 - y) * innerH;
    pts.push(`${i === 0 ? "M" : "L"}${px.toFixed(1)} ${py.toFixed(1)}`);
  }
  return pts.join(" ");
};
const palette = ["#00d4ff", "#a855f7", "#10b981", "#f59e0b", "#f43f5e"];
---

<figure class="not-prose my-10 rounded-xl border border-border bg-card overflow-hidden">
  <header class="px-6 py-4 border-b border-border bg-elevated/40">
    <div class="text-[10px] uppercase tracking-[0.14em] font-bold text-cyan">Plasma Decay</div>
    <div class="text-[15px] font-semibold text-text mt-0.5">Concentration vs. time</div>
  </header>

  <div class="p-6">
    <svg viewBox={`0 0 ${w} ${h}`} class="w-full h-auto" role="img">
      <!-- Grid -->
      {[0, 0.25, 0.5, 0.75, 1].map((p) => {
        const y = pad.t + p * innerH;
        return <>
          <line x1={pad.l} y1={y} x2={pad.l + innerW} y2={y} stroke="#222" stroke-dasharray="2 4" />
          <text x={pad.l - 8} y={y + 4} font-size="10" fill="#666" text-anchor="end" font-family="monospace">{Math.round((1 - p) * 100)}%</text>
        </>;
      })}
      <!-- Y axis label -->
      <text x="20" y={pad.t + innerH/2} font-size="10" fill="#888" transform={`rotate(-90 20 ${pad.t + innerH/2})`} text-anchor="middle" font-family="monospace" letter-spacing="1">PLASMA CONC.</text>
      <!-- X axis ticks at each half-life of the slowest -->
      {[1,2,3,4,5].map((m) => {
        const fraction = (m / 5);
        const px = pad.l + fraction * innerW;
        return <>
          <line x1={px} y1={pad.t} x2={px} y2={pad.t + innerH} stroke="#222" stroke-dasharray="2 4" />
          <text x={px} y={pad.t + innerH + 16} font-size="10" fill="#666" text-anchor="middle" font-family="monospace">{m}·t½</text>
        </>;
      })}
      <text x={pad.l + innerW/2} y={h - 10} font-size="10" fill="#888" text-anchor="middle" font-family="monospace" letter-spacing="1">TIME (multiples of slowest half-life)</text>

      <!-- 50% line callout -->
      <line x1={pad.l} y1={pad.t + 0.5 * innerH} x2={pad.l + innerW} y2={pad.t + 0.5 * innerH} stroke="#f59e0b" stroke-opacity="0.4" stroke-dasharray="6 4" />

      <!-- Curves -->
      {compounds.map((c, i) => {
        const color = c.color ?? palette[i % palette.length];
        return <path d={buildPath(c.halfLifeMin / Math.max(...compounds.map(x => x.halfLifeMin)) * (maxX / 5))} fill="none" stroke={color} stroke-width="2.25" />;
      })}
    </svg>

    <!-- Legend -->
    <div class="mt-4 grid sm:grid-cols-2 gap-2">
      {compounds.map((c, i) => {
        const color = c.color ?? palette[i % palette.length];
        return (
          <div class="flex items-center gap-3 px-3 py-2 rounded-md border border-border bg-bg/40">
            <span class="w-3 h-3 rounded-full flex-shrink-0" style={`background:${color}`}></span>
            <div class="flex-1 min-w-0">
              <div class="text-[13px] font-medium text-text truncate">{c.name}</div>
              <div class="text-[11px] font-mono text-text-muted">t½ ≈ {c.halfLife}</div>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  {caption && <figcaption class="px-6 py-3 border-t border-border text-[12px] text-text-muted">{caption}</figcaption>}
</figure>
