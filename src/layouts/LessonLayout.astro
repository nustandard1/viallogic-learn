---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

interface Props {
  module: CollectionEntry<"modules">;
  lesson: CollectionEntry<"lessons">;
}
const { module, lesson } = Astro.props;

const moduleSlug = module.id;
const lessonsAll = (await getCollection("lessons"))
  .filter((l) => l.data.module === moduleSlug)
  .sort((a, b) => a.data.order - b.data.order);

const idx = lessonsAll.findIndex((l) => l.id === lesson.id);
const prev = idx > 0 ? lessonsAll[idx - 1] : null;
const next = idx < lessonsAll.length - 1 ? lessonsAll[idx + 1] : null;
const num = String(module.data.number).padStart(2, "0");

const lessonSlug = (l: CollectionEntry<"lessons">) => l.id.split("/").pop()!;
---

<BaseLayout title={`${lesson.data.title} — ${module.data.title}`} description={lesson.data.summary}>
  <!-- Top progress bar -->
  <div class="sticky top-16 z-40 bg-bg/90 backdrop-blur-md border-b border-border">
    <div class="max-w-[var(--container-wide)] mx-auto px-6 py-2.5 flex items-center gap-4">
      <a href={`/modules/${moduleSlug}`} class="flex items-center gap-2 text-[12px] text-text-muted hover:text-text transition-colors min-w-0">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0"><path d="m15 18-6-6 6-6"/></svg>
        <span class="truncate">Module {num} · {module.data.title}</span>
      </a>
      <div class="flex-1 h-1 rounded-full bg-elevated overflow-hidden">
        <div
          class="h-full bg-gradient-to-r from-cyan to-purple transition-all"
          style={`width:${((idx + 1) / lessonsAll.length) * 100}%`}
          data-progress
        ></div>
      </div>
      <span class="text-[11px] font-mono text-text-muted whitespace-nowrap">
        Lesson {idx + 1}<span class="text-text-faint"> / {lessonsAll.length}</span>
      </span>
    </div>
  </div>

  <div class="max-w-[var(--container-wide)] mx-auto px-6 pt-10 pb-20 grid lg:grid-cols-[1fr_240px] gap-10">

    <!-- Lesson body -->
    <article class="min-w-0">
      <header class="mb-8">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-[10px] uppercase tracking-[0.14em] font-bold text-cyan">{module.data.category}</span>
          <span class="text-text-faint">·</span>
          <span class="text-[12px] text-text-muted">{lesson.data.duration} read</span>
        </div>
        <h1 class="text-[2.25rem] font-bold tracking-[-0.035em] leading-[1.05] mb-3 text-text">
          {lesson.data.title}
        </h1>
        <p class="text-[17px] text-text-muted leading-relaxed">
          {lesson.data.summary}
        </p>
      </header>

      <div class="prose">
        <slot />
      </div>

      <!-- Lesson navigation -->
      <nav class="mt-16 pt-8 border-t border-border grid sm:grid-cols-2 gap-4">
        {prev ? (
          <a href={`/modules/${moduleSlug}/${lessonSlug(prev)}`} class="group rounded-lg border border-border bg-card hover:border-cyan/40 hover:bg-elevated transition-all p-4">
            <div class="text-[10px] uppercase tracking-[0.14em] text-text-muted mb-1 flex items-center gap-1.5">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
              Previous lesson
            </div>
            <div class="text-[14px] font-medium text-text group-hover:text-cyan transition-colors leading-snug">{prev.data.title}</div>
          </a>
        ) : <div></div>}
        {next ? (
          <a
            href={`/modules/${moduleSlug}/${lessonSlug(next)}`}
            class="group rounded-lg border border-cyan/30 bg-cyan/[0.04] hover:border-cyan hover:bg-cyan/[0.08] transition-all p-4 text-right"
            data-mark-complete={lesson.id}
          >
            <div class="text-[10px] uppercase tracking-[0.14em] text-cyan/80 mb-1 flex items-center justify-end gap-1.5">
              Next lesson
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </div>
            <div class="text-[14px] font-medium text-text leading-snug">{next.data.title}</div>
          </a>
        ) : (
          <a
            href={`/modules/${moduleSlug}`}
            class="group rounded-lg border border-emerald/30 bg-emerald/[0.05] hover:bg-emerald/[0.1] transition-all p-4 text-right"
            data-mark-complete={lesson.id}
          >
            <div class="text-[10px] uppercase tracking-[0.14em] text-emerald mb-1 font-bold">Module complete</div>
            <div class="text-[14px] font-medium text-text leading-snug">Back to module overview</div>
          </a>
        )}
      </nav>
    </article>

    <!-- Right rail: lesson ToC -->
    <aside class="hidden lg:block">
      <div class="sticky top-32">
        <div class="text-[10px] uppercase tracking-[0.14em] font-bold text-text-muted mb-3">In this module</div>
        <nav class="space-y-1">
          {lessonsAll.map((l, i) => {
            const isActive = l.id === lesson.id;
            return (
              <a
                href={`/modules/${moduleSlug}/${lessonSlug(l)}`}
                data-lesson-id={l.id}
                class:list={[
                  "vl-toc-item flex items-start gap-3 px-3 py-2 rounded-md text-[13px] transition-colors",
                  isActive
                    ? "bg-elevated text-text border-l-2 border-cyan -ml-[2px]"
                    : "text-text-muted hover:text-text hover:bg-elevated/50"
                ]}
              >
                <span class:list={[
                  "vl-toc-number flex-shrink-0 w-5 h-5 rounded-full border flex items-center justify-center text-[10px] font-mono mt-0.5",
                  isActive ? "border-cyan text-cyan" : "border-border text-text-faint"
                ]}>{i + 1}</span>
                <span class="flex-1 leading-snug">{l.data.title}</span>
              </a>
            );
          })}
        </nav>

        <a href={`/modules/${moduleSlug}`} class="mt-6 inline-flex items-center gap-1.5 text-[12px] text-text-muted hover:text-cyan transition-colors">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Module overview
        </a>
      </div>
    </aside>
  </div>
</BaseLayout>

<script>
  const STORAGE_KEY = "vl-learn:completed-lessons";
  const getCompleted = (): string[] => {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]"); }
    catch { return []; }
  };
  const setCompleted = (ids: string[]) => localStorage.setItem(STORAGE_KEY, JSON.stringify(ids));

  // Mark current lesson complete when user clicks Next or Module-Complete
  document.querySelectorAll<HTMLAnchorElement>("[data-mark-complete]").forEach((a) => {
    a.addEventListener("click", () => {
      const id = a.dataset.markComplete!;
      const c = getCompleted();
      if (!c.includes(id)) {
        c.push(id);
        setCompleted(c);
      }
    });
  });

  // On load, mark ToC items completed
  const completed = getCompleted();
  document.querySelectorAll<HTMLAnchorElement>("[data-lesson-id]").forEach((el) => {
    if (completed.includes(el.dataset.lessonId!)) {
      const num = el.querySelector(".vl-toc-number");
      if (num) {
        num.classList.remove("border-border", "text-text-faint");
        num.classList.add("border-emerald/40", "text-emerald", "bg-emerald/[0.08]");
        num.innerHTML = '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      }
    }
  });
</script>
