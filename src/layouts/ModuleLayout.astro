---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

interface Props {
  module: CollectionEntry<"modules">;
}
const { module } = Astro.props;
const data = module.data;

const all = (await getCollection("modules"))
  .filter((m) => m.data.published)
  .sort((a, b) => a.data.number - b.data.number);

const idx = all.findIndex((m) => m.id === module.id);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;
const num = String(data.number).padStart(2, "0");
---

<BaseLayout title={`${data.title} — VialLogic Learn`} description={data.summary}>
  <article class="max-w-[var(--container-prose)] mx-auto px-6 pt-12 pb-20">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-[12px] text-text-muted mb-6">
      <a href="/" class="hover:text-text transition-colors">Course</a>
      <span class="text-text-faint">/</span>
      <span class="text-text-faint">Module {num}</span>
    </div>

    <!-- Header -->
    <header class="mb-10 pb-8 border-b border-border">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-[10px] uppercase tracking-[0.14em] font-bold text-cyan">{data.category}</span>
        <span class="text-text-faint">·</span>
        <span class="text-[12px] text-text-muted">{data.duration} read</span>
      </div>
      <h1 class="text-[2.5rem] font-bold tracking-[-0.035em] leading-[1.05] mb-3 text-text">
        {data.title}
      </h1>
      <p class="text-[18px] text-text-muted leading-relaxed">
        {data.subtitle}
      </p>
      {data.prerequisites.length > 0 && (
        <div class="mt-5 flex items-start gap-2 text-[12.5px] text-text-muted">
          <span class="text-text-faint">Prerequisites:</span>
          <span>{data.prerequisites.join(" · ")}</span>
        </div>
      )}
    </header>

    <!-- Body -->
    <div class="prose">
      <slot />
    </div>

    <!-- Module nav -->
    <nav class="mt-16 pt-8 border-t border-border grid grid-cols-2 gap-4">
      {prev ? (
        <a href={`/modules/${prev.id}`} class="group rounded-lg border border-border bg-card hover:border-cyan/40 hover:bg-elevated transition-all p-4">
          <div class="text-[10px] uppercase tracking-[0.14em] text-text-muted mb-1 flex items-center gap-1.5">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Previous
          </div>
          <div class="text-[14px] font-medium text-text group-hover:text-cyan transition-colors leading-snug">{prev.data.title}</div>
        </a>
      ) : <div></div>}
      {next ? (
        <a href={`/modules/${next.id}`} class="group rounded-lg border border-border bg-card hover:border-cyan/40 hover:bg-elevated transition-all p-4 text-right">
          <div class="text-[10px] uppercase tracking-[0.14em] text-text-muted mb-1 flex items-center justify-end gap-1.5">
            Next
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </div>
          <div class="text-[14px] font-medium text-text group-hover:text-cyan transition-colors leading-snug">{next.data.title}</div>
        </a>
      ) : <div></div>}
    </nav>
  </article>
</BaseLayout>
