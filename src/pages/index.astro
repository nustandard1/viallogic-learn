---
import BaseLayout from "../layouts/BaseLayout.astro";
import ModuleCard from "../components/ModuleCard.astro";
import { getCollection } from "astro:content";

const modules = (await getCollection("modules"))
  .sort((a, b) => a.data.number - b.data.number);

// Curriculum outline — modules that don't exist yet are listed as "coming soon"
const curriculum = [
  { number: 1, title: "Peptide Pharmacology Fundamentals", subtitle: "Receptors, half-lives, signaling cascades — the foundational vocabulary every peptide discussion uses.", category: "Foundations", duration: "20 min" },
  { number: 2, title: "Routes, Reconstitution & Dosing", subtitle: "How peptides actually reach the bloodstream, why route changes everything, and the math behind every injection.", category: "Foundations", duration: "15 min" },
  { number: 3, title: "Healing & Repair Pathways", subtitle: "Angiogenesis, fibroblast biology, and the cellular cascade that connects most regenerative peptides.", category: "Foundations", duration: "22 min" },
  { number: 4, title: "The Growth Hormone Axis", subtitle: "GHRH, GHRP, IGF-1 — the hypothalamic-pituitary system that governs an entire peptide category.", category: "Foundations", duration: "25 min" },
  { number: 5, title: "Evaluating Evidence & Quality", subtitle: "Reading research like an expert, spotting fraudulent claims, and understanding what a real COA actually tells you.", category: "Foundations", duration: "15 min" },
  { number: 6, title: "BPC-157 — Body Protection Compound", subtitle: "Mechanisms, tissue specificity, and why it works the way it does.", category: "Tissue Repair", duration: "25 min" },
  { number: 7, title: "TB-500 (Thymosin Beta-4 Fragment)", subtitle: "Systemic healing, actin sequestration, and stem cell mobilization — the complementary pair to BPC-157.", category: "Tissue Repair", duration: "22 min" },
  { number: 8, title: "GHK-Cu — The Copper Peptide", subtitle: "Gene expression, collagen synthesis, and connective tissue. The most studied skin and tissue peptide.", category: "Tissue Repair", duration: "20 min" },
  { number: 9, title: "GHRH Analogs — CJC-1295, Sermorelin & Tesamorelin", subtitle: "Three GHRH peptides, one mechanism — why duration and DAC technology change everything.", category: "GH Axis", duration: "22 min" },
  { number: 10, title: "GHRPs — Ipamorelin, GHRP-2, GHRP-6 & Hexarelin", subtitle: "The ghrelin receptor agonist family — what separates a clean pulse from a dirty spike.", category: "GH Axis", duration: "22 min" },
  { number: 11, title: "GLP-1 Analogs — Semaglutide, Tirzepatide & Retatrutide", subtitle: "The most prescribed peptides in history — mechanisms, clinical applications, and why retatrutide changes everything.", category: "Metabolic", duration: "25 min" },
  { number: 12, title: "Cognitive Peptides — Semax & Selank", subtitle: "Brain-targeted peptides, BDNF signaling, and the emerging nootropic category.", category: "Cognitive", duration: "20 min" },
  { number: 13, title: "Mitochondrial & Metabolic Peptides — MOTS-C & SS-31", subtitle: "Cellular energy, mitochondrial function, and the frontier of metabolic peptide research.", category: "Metabolic", duration: "20 min" },
];

const publishedNumbers = new Set(modules.filter(m => m.data.published).map(m => m.data.number));
---

<BaseLayout title="VialLogic Learn — Peptide Education">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 gradient-mesh pointer-events-none"></div>
    <div class="relative max-w-[var(--container-wide)] mx-auto px-6 pt-24 pb-16 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-elevated border border-border text-[11px] uppercase tracking-[0.14em] text-text-muted font-semibold mb-6 animate-fade-up">
        <span class="w-1.5 h-1.5 rounded-full bg-cyan pulse-glow"></span>
        Course in Active Development
      </div>
      <h1 class="text-[clamp(2.5rem,6vw,4.25rem)] font-bold tracking-[-0.04em] leading-[1.02] text-text max-w-3xl mx-auto animate-fade-up" style="animation-delay:0.1s">
        Peptide education
        <span class="bg-gradient-to-r from-cyan to-purple bg-clip-text text-transparent">done right.</span>
      </h1>
      <p class="mt-6 text-[19px] text-text-muted leading-relaxed max-w-2xl mx-auto animate-fade-up" style="animation-delay:0.2s">
        A structured, mechanism-grounded curriculum. From foundations to expert-level fluency — built so the people who finish it can hold their own with researchers.
      </p>
      <div class="mt-10 flex items-center justify-center gap-3 animate-fade-up" style="animation-delay:0.3s">
        <a href="#curriculum" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-cyan text-bg font-semibold text-[14px] hover:bg-cyan/90 transition-colors">
          Begin the course
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/about" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md border border-border text-text-dim hover:text-text hover:border-border-light transition-colors text-[14px] font-medium">
          What you'll learn
        </a>
      </div>
    </div>
  </section>

  <!-- Course principles -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 py-16">
    <div class="grid md:grid-cols-3 gap-6">
      <div class="rounded-xl border border-border bg-card p-6">
        <div class="w-10 h-10 rounded-lg bg-cyan/10 border border-cyan/20 flex items-center justify-center mb-4 text-cyan">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
        </div>
        <h3 class="text-[16px] font-semibold text-text mb-2">Mechanism, not marketing</h3>
        <p class="text-[14px] text-text-muted leading-relaxed">Every claim is grounded in molecular pathways. You'll learn <em>how</em> peptides work, not just what they're sold for.</p>
      </div>
      <div class="rounded-xl border border-border bg-card p-6">
        <div class="w-10 h-10 rounded-lg bg-purple/10 border border-purple/20 flex items-center justify-center mb-4 text-purple">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
        </div>
        <h3 class="text-[16px] font-semibold text-text mb-2">Tested by conversation</h3>
        <p class="text-[14px] text-text-muted leading-relaxed">Each module ends with a live interview — Dr. Harmon, an AI podcast host, asks follow-up questions until he's satisfied you actually understand it.</p>
      </div>
      <div class="rounded-xl border border-border bg-card p-6">
        <div class="w-10 h-10 rounded-lg bg-emerald/10 border border-emerald/20 flex items-center justify-center mb-4 text-emerald">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
        </div>
        <h3 class="text-[16px] font-semibold text-text mb-2">Honest about uncertainty</h3>
        <p class="text-[14px] text-text-muted leading-relaxed">What the research actually shows — and what it doesn't. The limitations are part of the curriculum, not an afterthought.</p>
      </div>
    </div>
  </section>

  <!-- Curriculum -->
  <section id="curriculum" class="max-w-[var(--container-wide)] mx-auto px-6 py-12">
    <div class="mb-10">
      <div class="text-[11px] uppercase tracking-[0.14em] text-cyan font-bold mb-2">Curriculum</div>
      <h2 class="text-[2rem] font-bold text-text tracking-[-0.025em] mb-2">The full course outline</h2>
      <p class="text-[15px] text-text-muted max-w-2xl">Foundations first, then deep-dive modules per compound. Modules unlock as they're published — start with what's available, the rest will follow.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      {curriculum.map((m) => {
        const published = publishedNumbers.has(m.number);
        const moduleEntry = modules.find(x => x.data.number === m.number);
        const href = moduleEntry ? `/modules/${moduleEntry.id}` : "#";
        return (
          <ModuleCard
            number={m.number}
            title={m.title}
            subtitle={m.subtitle}
            category={m.category}
            duration={m.duration}
            href={href}
            available={published}
          />
        );
      })}
    </div>
  </section>
</BaseLayout>
