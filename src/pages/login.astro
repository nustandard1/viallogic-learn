---
import BaseLayout from '../layouts/BaseLayout.astro';

const AUTH_COOKIE  = 'vl_auth';
const AUTH_TOKEN   = 'vl_granted';
const SITE_PASSWORD = import.meta.env.SITE_PASSWORD || 'Lcr51582!';

let error = false;

if (Astro.request.method === 'POST') {
    const form = await Astro.request.formData();
    const password = form.get('password')?.toString() ?? '';
    if (password === SITE_PASSWORD) {
        Astro.cookies.set(AUTH_COOKIE, AUTH_TOKEN + ':' + SITE_PASSWORD, {
            path: '/',
            httpOnly: true,
            sameSite: 'lax',
            maxAge: 60 * 60 * 24 * 30, // 30 days
        });
        return Astro.redirect('/');
    }
    error = true;
}
---

<BaseLayout title="VialLogic Learn">
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="w-full max-w-sm">
      <div class="text-center mb-10">
        <span class="text-2xl font-bold tracking-tight text-text">
          Vial<span class="bg-gradient-to-r from-cyan to-purple bg-clip-text text-transparent">Logic</span>
          <span class="text-text-muted font-normal ml-1">Learn</span>
        </span>
        <p class="mt-3 text-sm text-text-muted">This course is in active development.<br>Enter the access password to continue.</p>
      </div>

      <form method="POST" class="space-y-4">
        <div>
          <input
            type="password"
            name="password"
            placeholder="Password"
            autofocus
            class="w-full px-4 py-3 rounded-lg bg-elevated border border-border text-text placeholder:text-text-muted focus:outline-none focus:border-cyan transition-colors text-sm"
          />
        </div>
        {error && (
          <p class="text-xs text-rose-400">Incorrect password. Try again.</p>
        )}
        <button
          type="submit"
          class="w-full py-3 rounded-lg bg-cyan text-bg font-semibold text-sm hover:bg-cyan/90 transition-colors"
        >
          Enter
        </button>
      </form>
    </div>
  </div>
</BaseLayout>
