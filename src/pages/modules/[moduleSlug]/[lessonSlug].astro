---
import LessonLayout from "../../../layouts/LessonLayout.astro";
import { getCollection, render } from "astro:content";

const { moduleSlug, lessonSlug } = Astro.params;

const modules = await getCollection("modules");
const module = modules.find((m) => m.id === moduleSlug);
if (!module) return Astro.redirect("/");

const lessons = await getCollection("lessons");
const lesson = lessons.find((l) => l.id === `${moduleSlug}/${lessonSlug}`);
if (!lesson) return Astro.redirect(`/modules/${moduleSlug}`);

const { Content } = await render(lesson);
---

<LessonLayout module={module} lesson={lesson}>
  <Content />
</LessonLayout>
